# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/jobtracker?schema=public"

# JWT
JWT_ACCESS_SECRET="your-super-secret-access-key-change-me"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-me"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# Server
PORT=5000
NODE_ENV=development

# Client origins for CORS (comma-separated)
# Examples:
# CLIENT_URL="http://localhost:5173"
# CLIENT_URL="https://your-frontend.vercel.app,https://your-custom-domain.com"
CLIENT_URL="http://localhost:5173"
