# Database - use docker-compose.yml to spin up a local Postgres, or provide a connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/jobtracker?schema=public"

# JWT secrets - CHANGE THESE before deploying!
JWT_ACCESS_SECRET="replace-with-a-long-random-string-at-least-32-chars"
JWT_REFRESH_SECRET="replace-with-a-different-long-random-string-at-least-32-chars"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# Server
PORT=5000
NODE_ENV=development

# Client URL (for CORS) - change to your deployed frontend URL in production
CLIENT_URL="http://localhost:5173"
